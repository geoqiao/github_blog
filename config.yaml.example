# ============================================
# 核心配置（必填）
# ============================================
blog:
  title: Your Blog Name
  description: A short description of your blog.
  url: https://yourname.github.io/
  author: Your Name

github:
  repo: yourname/yourname.github.io

about:
  bio: |
    在这里介绍你自己。
    可以写多行。
  expertise:
    - 技能 1
    - 技能 2
    - 技能 3
  links:
    - name: GitHub
      url: https://github.com/yourname
    # 可以添加更多链接
    # - name: Twitter
    #   url: https://twitter.com/yourname

# ============================================
# 个性化配置（可选，有合理默认值）
# ============================================
# theme:
#   name: BearMinimal

# navigation:
#   items:
#     - name: Blog
#       url: /blog/
